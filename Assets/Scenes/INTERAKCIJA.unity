  requireLineOfSight: 1
  disableAfterUse: 0
  npcName: Caretaker
  firstConversation: Take the key. I am tired of pretending this corridor is closed
    for renovation.
  repeatConversation: I already gave you the key. Try using it instead of staring
    at me like unpaid guilt.
  firstNode:
    speakerName: Caretaker
    promptLine: Choose your response.
    choices:
    - text: I need the Service Key.
      responseLine: Take the key. I am tired of pretending this corridor is closed
        for renovation.
      milestoneId: npc_reward_key
      isLeave: 0
    - text: Any quick advice?
      responseLine: Stay calm, stay brief, and don't draw attention.
      milestoneId: 
      isLeave: 0
    - text: Leave conversation.
      responseLine: You step back from the conversation.
      milestoneId: 
      isLeave: 1
  repeatNode:
    speakerName: Caretaker
    promptLine: Choose your response.
    choices:
    - text: Do you have anything else for me?
      responseLine: I already gave you the key. Try using it instead of staring at
        me like unpaid guilt.
      milestoneId: 
      isLeave: 0
    - text: Any update?
      responseLine: No updates. Keep moving.
      milestoneId: 
      isLeave: 0
    - text: Leave conversation.
      responseLine: You step back from the conversation.
      milestoneId: 
      isLeave: 1
